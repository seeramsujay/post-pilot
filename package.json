{
  "name": "postpilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "vite",
    "dev:server": "esbuild src/server/index.ts --bundle --platform=node --format=cjs --outfile=dist/server/index.js --external:@devvit/web/server --external:@devvit/public-api --watch",
    "build:client": "vite build",
    "build:server": "esbuild src/server/index.ts --bundle --platform=node --format=cjs --outfile=dist/server/index.js --external:@devvit/web/server --external:@devvit/public-api",
    "build": "npm run build:client && npm run build:server",
    "test": "vitest run"
  },
  "dependencies": {
    "@devvit/public-api": "0.13.0",
    "@devvit/web": "0.13.0",
    "hono": "^4.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "devvit": "0.13.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.4.0"
  }
}
